{
  "name": "frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc",
    "preview": "vite preview",
    "start": "vite build && tsc && vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix",
    "check:staged": "git diff --cached --name-only --diff-filter=ACM | grep -E '\\.(ts|tsx|jsx|js|scss|css)$' | xargs -r npm run format -- && git diff --cached --name-only --diff-filter=ACM | grep -E '\\.(ts|tsx|jsx|js)$' | xargs -r npm run lint --"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "bootstrap": "^5.3.8",
    "lucide-react": "^0.545.0",
    "moment": "^2.30.1",
    "posthog-js": "^1.298.1",
    "react": "^19.0.0",
    "react-big-calendar": "^1.19.4",
    "react-bootstrap": "^2.10.10",
    "react-bootstrap-icons": "^1.11.6",
    "react-dom": "^19.0.0",
    "react-select": "^5.10.2",
    "tailwindcss": "^4.0.6",
    "vetilib": "file:..",
    "vetilib-shared": "file:../shared",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "^0.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.8",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^27.0.0",
    "prettier": "^3.5.3",
    "sass": "1.77.8",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^3.0.5",
    "web-vitals": "^5.1.0"
  }
}
