generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model addresses {
  id                  Int                   @id @default(autoincrement())
  street              String                @db.VarChar(80)
  citycode            String                @db.VarChar(12)
  city                String                @db.VarChar(60)
  country             String                @db.VarChar(150)
  longitude           Float
  latitude            Float
  persons             persons[]
  veterinarypractices veterinarypractices[]
}

model animals {
  id                     Int                      @id @default(autoincrement())
  name                   String                   @db.VarChar(100)
  dateofbirth            DateTime?                @db.Date
  dateofbirthisexact     Boolean?
  weightingram           Int?
  heightincm             Int?
  timeofdeath            DateTime?                @db.Date
  iscastrated            Boolean?
  lifestyle              husbandarysystem?
  sex                    sexes                    @default(notknown)
  fk_animaltypeid        Int
  fk_animalgroupid       Int?
  animal_has_races       animal_has_races[]
  animal_has_vaccination animal_has_vaccination[]
  animalgroup            animalgroup?             @relation(fields: [fk_animalgroupid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  animaltypes            animaltypes              @relation(fields: [fk_animaltypeid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  appointments           appointments[]
  person_has_animal      person_has_animal[]
  recipes                recipes[]
}

model animaltypes {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(100)
  animalraces animalraces[]
  animals     animals[]
}

model appointments {
  id                      Int                      @id @default(autoincrement())
  starttime               DateTime                 @db.Timestamp(6)
  endtime                 DateTime                 @db.Timestamp(6)
  fk_animalid             Int?
  fk_veterinaryid         Int
  fk_veterinarypracticeid Int
  fk_serviceid            Int?
  appointment_has_review  appointment_has_review[]
  animals                 animals?                 @relation(fields: [fk_animalid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  services                services?                @relation(fields: [fk_serviceid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  veterinaries            veterinaries             @relation(fields: [fk_veterinaryid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  veterinarypractices     veterinarypractices      @relation(fields: [fk_veterinarypracticeid], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model person_has_animal {
  fk_personid Int
  fk_animalid Int
  animals     animals @relation(fields: [fk_animalid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  persons     persons @relation(fields: [fk_personid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([fk_personid, fk_animalid])
}

model persons {
  id                                      Int                                       @id @default(autoincrement())
  firstname                               String                                    @db.VarChar(60)
  lastname                                String                                    @db.VarChar(60)
  sex                                     sexes
  dateofbirth                             DateTime                                  @db.Date
  fk_address                              Int
  phone                                   String                                    @db.VarChar(20)
  email                                   String                                    @unique @db.VarChar(100)
  password                                String                                    @db.VarChar(255)
  person_has_animal                       person_has_animal[]
  person_has_favorized_veterinarypractice person_has_favorized_veterinarypractice[]
  addresses                               addresses                                 @relation(fields: [fk_address], references: [id], onDelete: NoAction, onUpdate: NoAction)
  veterinaries                            veterinaries?
}

model specializations {
  id                            Int                             @id @default(autoincrement())
  name                          String                          @db.VarChar(100)
  veterinary_has_specialization veterinary_has_specialization[]
}

model veterinaries {
  id                            Int                             @id
  infoemail                     String?                         @db.VarChar(100)
  fk_veterinarypractice         Int?
  appointments                  appointments[]
  veterinarypractices           veterinarypractices?            @relation(fields: [fk_veterinarypractice], references: [id], onDelete: NoAction, onUpdate: NoAction)
  persons                       persons                         @relation(fields: [id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  veterinary_has_invitation     veterinary_has_invitation[]
  veterinary_has_specialization veterinary_has_specialization[]
}

model veterinary_has_specialization {
  fk_veterinaryid     Int
  fk_specializationid Int
  specializations     specializations @relation(fields: [fk_specializationid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  veterinaries        veterinaries    @relation(fields: [fk_veterinaryid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([fk_veterinaryid, fk_specializationid])
}

model veterinarypractices {
  id                                      Int                                       @id @default(autoincrement())
  name                                    String                                    @db.VarChar(200)
  phone                                   String                                    @db.VarChar(20)
  infoemail                               String                                    @db.VarChar(100)
  email                                   String                                    @db.VarChar(100)
  password                                String                                    @db.VarChar(255)
  website                                 String?                                   @db.VarChar(150)
  info                                    String?
  fk_addressid                            Int
  appointments                            appointments[]
  person_has_favorized_veterinarypractice person_has_favorized_veterinarypractice[]
  services                                services[]
  veterinaries                            veterinaries[]
  veterinary_has_invitation               veterinary_has_invitation[]
  addresses                               addresses                                 @relation(fields: [fk_addressid], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model animal_has_races {
  fk_animalid     Int
  fk_animalraceid Int
  animals         animals     @relation(fields: [fk_animalid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  animalraces     animalraces @relation(fields: [fk_animalraceid], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([fk_animalid, fk_animalraceid])
}

model animal_has_vaccination {
  id                Int          @id @default(autoincrement())
  dateofvaccination DateTime     @db.Date
  fk_animalid       Int
  fk_vaccinationid  Int
  animals           animals      @relation(fields: [fk_animalid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vaccinations      vaccinations @relation(fields: [fk_vaccinationid], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model animalgroup {
  id      Int       @id @default(autoincrement())
  name    String?   @db.VarChar(100)
  animals animals[]
}

model animalraces {
  id               Int                @id @default(autoincrement())
  name             String             @db.VarChar(100)
  fk_animaltypeid  Int
  animal_has_races animal_has_races[]
  animaltypes      animaltypes        @relation(fields: [fk_animaltypeid], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model appointment_has_review {
  fk_appointmentid Int
  fk_reviewid      Int
  appointments     appointments @relation(fields: [fk_appointmentid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviews          reviews      @relation(fields: [fk_reviewid], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([fk_appointmentid, fk_reviewid])
}

model medications {
  id      Int       @id @default(autoincrement())
  name    String    @unique @db.VarChar(100)
  recipes recipes[]
}

model recipes {
  id              Int         @id @default(autoincrement())
  fk_animalid     Int
  fk_medicationid Int
  starting        DateTime    @db.Date
  enddate         DateTime    @db.Date
  instructions    String?
  animals         animals     @relation(fields: [fk_animalid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  medications     medications @relation(fields: [fk_medicationid], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  id                     Int                      @id @default(autoincrement())
  contentment            Int                      @db.SmallInt
  waitingtime            Int                      @db.SmallInt
  kindness               Int                      @db.SmallInt
  servicequality         Int                      @db.SmallInt
  price                  Int                      @db.SmallInt
  comment                String?
  appointment_has_review appointment_has_review[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model services {
  id                         Int                  @id @default(autoincrement())
  name                       String               @db.VarChar(100)
  estimateddurationinminutes Int                  @default(0)
  fk_veterinarypracticeid    Int?
  appointments               appointments[]
  veterinarypractices        veterinarypractices? @relation(fields: [fk_veterinarypracticeid], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model vaccinations {
  id                     Int                      @id @default(autoincrement())
  name                   String                   @unique @db.VarChar(100)
  animal_has_vaccination animal_has_vaccination[]
}

model veterinary_has_invitation {
  fk_veterinaryid         Int
  fk_veterinarypracticeid Int
  dateofinvitation        DateTime            @db.Date
  veterinaries            veterinaries        @relation(fields: [fk_veterinaryid], references: [id], onDelete: NoAction, onUpdate: NoAction)
  veterinarypractices     veterinarypractices @relation(fields: [fk_veterinarypracticeid], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([fk_veterinaryid, fk_veterinarypracticeid])
}

model person_has_favorized_veterinarypractice {
  fk_personid             Int
  fk_veterinarypracticeid Int
  veterinarypractices     veterinarypractices @relation(fields: [fk_veterinarypracticeid], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "person_has_favorized_veterinarypra_fk_veterinarypracticeid_fkey")
  persons                 persons             @relation(fields: [fk_personid], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([fk_personid, fk_veterinarypracticeid])
}

enum sexes {
  notknown
  male
  female
  notapplicable
}

enum husbandarysystem {
  indoor
  indoorPlusSpace
  indoorWithFreshAir
  outdoorRunsFreeRange
  organic
}

enum paymentstatus {
  unpaid
  paid
  cancelled
}
