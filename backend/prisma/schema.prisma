generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Address {
  id                  Int                  @id @default(autoincrement())
  street              String               @db.VarChar(80)
  cityCode            String               @map("citycode") @db.VarChar(12)
  city                String               @db.VarChar(60)
  country             String               @db.VarChar(150)
  longitude           Float
  latitude            Float
  persons             Person[]
  veterinaryPractices VeterinaryPractice[]

  @@map("addresses")
}

model Animal {
  id                    Int                    @id @default(autoincrement())
  name                  String                 @db.VarChar(100)
  dateOfBirth           DateTime?              @map("dateofbirth") @db.Date
  dateOfBirthIsExact    Boolean?               @map("dateofbirthisexact")
  weightInGram          Int?                   @map("weightingram")
  heightInCm            Int?                   @map("heightincm")
  timeOfDeath           DateTime?              @map("timeofdeath") @db.Date
  isCastrated           Boolean                @map("iscastrated")
  lifestyle             lifestyles             @default(indoor)
  picturePath           String?                @map("picturepath") @db.VarChar(256)
  sex                   Sexes                  @default(not_known)
  animalTypeId          Int                    @map("fk_animaltypeid")
  animalGroupId         Int?                   @map("fk_animalgroupid")
  animalHasRaces        AnimalHasRace[]        @relation("AnimalToRaces")
  animalHasVaccinations AnimalHasVaccination[]
  animalGroup           AnimalGroup?           @relation(fields: [animalGroupId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  animalType            AnimalType             @relation(fields: [animalTypeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  appointments          Appointment[]
  personHasAnimals      PersonHasAnimal[]
  recipes               Recipe[]

  @@map("animals")
}

model Appointment {
  id                     Int                     @id @default(autoincrement())
  startTime              DateTime                @map("starttime") @db.Timestamp(6)
  endTime                DateTime                @map("endtime") @db.Timestamp(6)
  animalId               Int?                    @map("fk_animalid")
  veterinaryId           Int                     @map("fk_veterinaryid")
  veterinaryPracticeId   Int                     @map("fk_veterinarypracticeid")
  serviceId              Int?                    @map("fk_serviceid")
  notes                  String?
  appointmentHasReviews  AppointmentHasReview[]
  appointmentHasServices AppointmentHasService[]
  animal                 Animal?                 @relation(fields: [animalId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  service                Service?                @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  veterinarian           Veterinarian            @relation(fields: [veterinaryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  veterinaryPractice     VeterinaryPractice      @relation(fields: [veterinaryPracticeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("appointments")
}

model PersonHasAnimal {
  personId Int    @map("fk_personid")
  animalId Int    @map("fk_animalid")
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([personId, animalId])
  @@map("person_has_animal")
}

model Person {
  id                                    Int                                    @id @default(autoincrement())
  firstName                             String                                 @map("firstname") @db.VarChar(60)
  lastName                              String                                 @map("lastname") @db.VarChar(60)
  sex                                   Sexes
  dateOfBirth                           DateTime                               @map("dateofbirth") @db.Date
  addressId                             Int                                    @map("fk_address")
  phone                                 String                                 @db.VarChar(20)
  email                                 String                                 @unique @db.VarChar(100)
  password                              String                                 @db.VarChar(255)
  picturePath                           String?                                @map("picturepath") @db.VarChar(256)
  passwordResetTokens                   PasswordResetToken[]
  personHasAnimals                      PersonHasAnimal[]
  person_has_confirmation_code          person_has_confirmation_code?
  personHasFavorizedVeterinaryPractices PersonHasFavorizedVeterinaryPractice[]
  address                               Address                                @relation(fields: [addressId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  veterinarian                          Veterinarian?

  @@map("persons")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamp(6)
  usedAt    DateTime? @map("used_at") @db.Timestamp(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  person    Person    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expiresAt], map: "idx_password_reset_tokens_expires_at")
  @@index([userId], map: "idx_password_reset_tokens_user_id")
  @@map("password_reset_tokens")
}

model Veterinarian {
  id                            Int                            @id
  infoEmail                     String?                        @map("infoemail") @db.VarChar(100)
  fk_veterinarypracticeid       Int?
  appointments                  Appointment[]
  veterinaryPractice            VeterinaryPractice?            @relation(fields: [fk_veterinarypracticeid], references: [id], onDelete: Cascade, onUpdate: NoAction)
  person                        Person                         @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  veterinaryCanTreatAnimalTypes VeterinaryCanTreatAnimalType[]
  veterinaryHasInvitations      VeterinaryHasInvitation[]
  veterinaryHasServices         VeterinaryHasService[]

  @@map("veterinarians")
}

model VeterinaryPractice {
  id                                    Int                                    @id @default(autoincrement())
  name                                  String                                 @db.VarChar(200)
  phone                                 String                                 @db.VarChar(20)
  infoEmail                             String                                 @map("infoemail") @db.VarChar(100)
  email                                 String                                 @unique @db.VarChar(100)
  password                              String                                 @db.VarChar(255)
  website                               String?                                @db.VarChar(150)
  info                                  String?
  addressId                             Int                                    @map("fk_addressid")
  appointments                          Appointment[]
  personHasFavorizedVeterinaryPractices PersonHasFavorizedVeterinaryPractice[]
  veterinarians                         Veterinarian[]
  veterinaryHasInvitations              VeterinaryHasInvitation[]
  address                               Address                                @relation(fields: [addressId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("veterinarypractices")
}

model AnimalHasRace {
  animalId     Int        @map("fk_animalid")
  animalRaceId Int        @map("fk_animalraceid")
  animal       Animal     @relation("AnimalToRaces", fields: [animalId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  animalRace   AnimalRace @relation(fields: [animalRaceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([animalId, animalRaceId])
  @@map("animal_has_races")
}

model AnimalHasVaccination {
  id                Int         @id @default(autoincrement())
  dateOfVaccination DateTime    @map("dateofvaccination") @db.Date
  animalId          Int         @map("fk_animalid")
  vaccinationId     Int         @map("fk_vaccinationid")
  animal            Animal      @relation(fields: [animalId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vaccination       Vaccination @relation(fields: [vaccinationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("animal_has_vaccination")
}

model AppointmentHasReview {
  appointmentId Int         @map("fk_appointmentid")
  reviewId      Int         @map("fk_reviewid")
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  review        Review      @relation(fields: [reviewId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([appointmentId, reviewId])
  @@map("appointment_has_review")
}

model Medication {
  id      Int      @id @default(autoincrement())
  name    String   @unique @db.VarChar(100)
  recipes Recipe[]

  @@map("medications")
}

model Recipe {
  id           Int        @id @default(autoincrement())
  animalId     Int        @map("fk_animalid")
  medicationId Int        @map("fk_medicationid")
  starting     DateTime   @db.Date
  endDate      DateTime   @map("enddate") @db.Date
  instructions String?
  animal       Animal     @relation(fields: [animalId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("recipes")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Review {
  id                    Int                    @id @default(autoincrement())
  contentment           Int                    @db.SmallInt
  waitingTime           Int                    @map("waitingtime") @db.SmallInt
  kindness              Int                    @db.SmallInt
  serviceQuality        Int                    @map("servicequality") @db.SmallInt
  price                 Int                    @db.SmallInt
  comment               String?
  appointmentHasReviews AppointmentHasReview[]

  @@map("reviews")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Service {
  id                     Int                     @id @default(autoincrement())
  name                   String                  @unique @db.VarChar(100)
  appointmentHasServices AppointmentHasService[]
  appointments           Appointment[]
  veterinaryHasServices  VeterinaryHasService[]

  @@map("services")
}

model Vaccination {
  id                    Int                    @id @default(autoincrement())
  name                  String                 @unique @db.VarChar(100)
  animalHasVaccinations AnimalHasVaccination[]

  @@map("vaccinations")
}

model VeterinaryHasInvitation {
  veterinaryId         Int                @map("fk_veterinaryid")
  veterinaryPracticeId Int                @map("fk_veterinarypracticeid")
  dateOfInvitation     DateTime           @map("dateofinvitation") @db.Date
  veterinarian         Veterinarian       @relation(fields: [veterinaryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  veterinaryPractice   VeterinaryPractice @relation(fields: [veterinaryPracticeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([veterinaryId, veterinaryPracticeId])
  @@map("veterinary_has_invitation")
}

model PersonHasFavorizedVeterinaryPractice {
  personId             Int                @map("fk_personid")
  veterinaryPracticeId Int                @map("fk_veterinarypracticeid")
  veterinaryPractice   VeterinaryPractice @relation(fields: [veterinaryPracticeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "person_has_favorized_veterinarypra_fk_veterinarypracticeid_fkey")
  person               Person             @relation(fields: [personId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([personId, veterinaryPracticeId])
  @@map("person_has_favorized_veterinarypractice")
}

model AppointmentHasService {
  appointmentId Int         @map("fk_appointmentid")
  serviceId     Int         @map("fk_serviceid")
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([appointmentId, serviceId])
  @@map("appointment_has_service")
}

model VeterinaryCanTreatAnimalType {
  veterinaryId Int          @map("fk_veterinaryid")
  animalTypeId Int          @map("fk_animaltypeid")
  animalType   AnimalType   @relation(fields: [animalTypeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  veterinarian Veterinarian @relation(fields: [veterinaryId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([veterinaryId, animalTypeId])
  @@map("veterinary_can_treat_animaltype")
}

model VeterinaryHasService {
  veterinaryId Int          @map("fk_veterinaryid")
  serviceId    Int          @map("fk_serviceid")
  notes        String?
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  veterinarian Veterinarian @relation(fields: [veterinaryId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([veterinaryId, serviceId])
  @@map("veterinary_has_service")
}

model AnimalGroup {
  id      Int      @id @default(autoincrement())
  name    String   @db.VarChar(100)
  animals Animal[]

  @@map("animal_groups")
}

model AnimalRace {
  id             Int             @id @default(autoincrement())
  name           String          @db.VarChar(100)
  animalTypeId   Int             @map("fk_animaltypeid")
  animalHasRaces AnimalHasRace[]
  animalType     AnimalType      @relation(fields: [animalTypeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("animal_races")
}

model AnimalType {
  id                            Int                            @id @default(autoincrement())
  name                          String                         @db.VarChar(100)
  animalRaces                   AnimalRace[]
  animals                       Animal[]
  veterinaryCanTreatAnimalTypes VeterinaryCanTreatAnimalType[]

  @@map("animal_types")
}

model password_reset_tokens {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String    @unique @db.VarChar(255)
  expires_at DateTime  @db.Timestamp(6)
  used_at    DateTime? @db.Timestamp(6)
  created_at DateTime  @default(now()) @db.Timestamp(6)
  persons    Person    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_password_reset_tokens_expires_at")
  @@index([user_id], map: "idx_password_reset_tokens_user_id")
}

model person_has_confirmation_code {
  fk_personid    Int      @id
  code           String   @db.Char(6)
  dateofcreation DateTime @db.Date
  verified       Boolean
  persons        Person   @relation(fields: [fk_personid], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum Sexes {
  not_known
  male
  female
  not_applicable

  @@map("sexes")
}

enum PaymentStatus {
  unpaid
  paid
  cancelled

  @@map("paymentstatus")
}

enum lifestyles {
  indoor
  outdoor
  mixed

  @@map("lifestyles")
}
