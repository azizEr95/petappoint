{
  "name": "vetlib",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "vetlib": "npm --prefix ./db run db && npm-run-all buildProject migrateDB && npm-run-all --parallel startBackend startFrontend",
    "startBackend": "npm --prefix ./backend run start",
    "startFrontend": "npm --prefix ./frontend run dev",
    "buildProject": "npm --prefix ./backend install && npm --prefix ./frontend install",
    "migrateDB": "npm --prefix ./backend run prisma",
    "vetlib:detached": "docker-compose up --build -d",
    "stop": "docker-compose down",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "prisma": "cd backend && npm run prisma"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "zod": "^4.1.12"
  }
}
