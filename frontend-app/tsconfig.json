{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "petappoint-shared/*": ["../shared/src/*"]
    },
    "strict": true
  },
  "include": [
    "app/**/*",
    "src/**/*",
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "env.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "ios",
    "android"
  ]
}
