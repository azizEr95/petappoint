{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./*",
      ],
      "@src/*": [
        "./src/*",
      ],
      "petappoint-shared/*": [
        "../shared/src/*"
      ],
      "tailwind.config": [
        "./tailwind.config.js"
      ]
    },
    "strict": true
  },
  "include": [
    "app/**/*",
    "src/**/*",
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "env.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "ios",
    "android"
  ]
}